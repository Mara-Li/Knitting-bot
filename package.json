{
	"name": "knitting",
	"version": "3.1.6",
	"description": "A bot used to add new user automatically in thread, without pinging them!",
	"private": true,
	"type": "module",
	"engines": {
		"node": "24.14.0"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"build": "pnpm run typecheck && node esbuild.config.mjs",
		"build:watch": "node esbuild.config.mjs --watch",
		"prestart": "pnpm run build",
		"start": "pm2 start pm2.config.cjs",
		"stop": "pm2 stop knitting",
		"prerestart": "pnpm run build",
		"restart": "pm2 restart knitting",
		"delete": "pm2 delete knitting",
		"dev": "tsx watch --clear-screen=false src/index.ts",
		"dev:prod": "cross-env ENV=production tsx watch --clear-screen=false src/index.ts",
		"prerelease": "pnpm run typecheck",
		"release": "commit-and-tag-version",
		"lint": "biome check src/ --write --unsafe",
		"prod": "pnpm build && node dist/src/index.js"
	},
	"commit-and-tag-version": {
		"t": ""
	},
	"dependencies": {
		"ansi-colors": "^4.1.3",
		"commit-and-tag-version": "^12.7.3",
		"cross-env": "^10.1.0",
		"discord.js": "^14.26.4",
		"dotenv": "^17.4.2",
		"enmap": "npm:@dicelette/enmap",
		"esbuild": "^0.28.1",
		"esbuild-fix-imports-plugin": "^1.0.23",
		"glob": "^13.0.6",
		"i18next": "^26.3.1",
		"load-tsconfig": "^0.2.5",
		"p-limit": "^7.3.0",
		"readline-sync": "^1.4.10",
		"uniformize": "^2.6.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"dedent": "^1.7.2",
		"nodemon": "^3.1.14",
		"ts-node": "^10.9.2",
		"ts-node-dev": "^2.0.0",
		"tsc-alias": "^1.8.17",
		"tsconfig-paths": "^4.2.0",
		"tslib": "^2.8.1",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"better-sqlite3",
			"esbuild"
		],
		"overrides": {
			"undici@<6.23.0": ">=6.23.0",
			"undici@>=6.0.0 <6.24.0": ">=6.24.0",
			"undici@<6.24.0": ">=6.24.0",
			"fast-xml-parser@>=5.0.0 <5.5.6": ">=5.5.6",
			"handlebars@>=4.0.0 <=4.7.8": ">=4.7.9",
			"brace-expansion@<1.1.13": ">=1.1.13",
			"brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
			"handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
			"picomatch@<2.3.2": ">=2.3.2",
			"yaml@>=2.0.0 <2.8.3": ">=2.8.3",
			"handlebars@>=4.6.0 <=4.7.8": ">=4.7.9",
			"lodash-es@>=4.0.0 <=4.17.23": ">=4.18.0",
			"lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
			"lodash-es@<=4.17.23": ">=4.18.0",
			"lodash@<=4.17.23": ">=4.18.0",
			"fast-xml-parser@>=5.0.0 <5.5.7": ">=5.5.7",
			"fast-xml-parser@<5.7.0": ">=5.7.0",
			"fast-xml-builder@<=1.1.6": ">=1.1.7",
			"ws@>=8.0.0 <8.20.1": ">=8.20.1",
			"brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
			"esbuild@>=0.17.0 <0.28.1": ">=0.28.1",
			"esbuild@>=0.27.3 <0.28.1": ">=0.28.1"
		}
	}
}
